# ============================================================
# Medoq Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Database (AWS RDS PostgreSQL) ────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<RDS_ENDPOINT>:5432/medoq_db
SPRING_DATASOURCE_USERNAME=medoq_user
SPRING_DATASOURCE_PASSWORD=change_me_strong_password

# ── Redis (ElastiCache or self-hosted) ───────────────────────
SPRING_REDIS_HOST=<REDIS_HOST>
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=change_me_redis_password

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_at_least_64_character_random_secret_key
JWT_EXPIRATION=86400000          # 24h in ms
JWT_REFRESH_EXPIRATION=604800000 # 7d in ms

# ── Encryption (AES-256 for stored sensitive data) ───────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_aes_key

# ── Wave Mobile Money ─────────────────────────────────────────
WAVE_API_KEY=wave_sn_prod_xxxxxxxxxxxxxxxxxxxxxxxx
WAVE_WEBHOOK_SECRET=wave_webhook_prod_secret

# ── Orange Money ─────────────────────────────────────────────
ORANGE_MERCHANT_KEY=om_prod_merchant_key
ORANGE_API_URL=https://api.orange.sn/orange-money-webpay/sn/v1
ORANGE_NOTIF_TOKEN=om_prod_notif_token

# ── Africa's Talking (SMS + USSD) ────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_at_username
AT_SENDER_ID=Medoq
AT_USSD_CODE=*338#

# ── Firebase Cloud Messaging (FCM) ───────────────────────────
# Path to the service account JSON downloaded from Firebase console
# Leave blank to use GOOGLE_APPLICATION_CREDENTIALS env var instead
FCM_SERVICE_ACCOUNT_PATH=/opt/medoq/secrets/firebase-service-account.json
# Or set: GOOGLE_APPLICATION_CREDENTIALS=/opt/medoq/secrets/firebase-service-account.json

# ── AWS ───────────────────────────────────────────────────────
# For local dev / GitHub Actions CI. On EC2, prefer IAM instance role instead.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=eu-west-1

# S3 buckets
AWS_S3_INVOICES_BUCKET=medoq-invoices-prod
AWS_S3_ASSETS_BUCKET=medoq-assets-prod

# ECR registry (for deploy workflow)
ECR_REGISTRY=123456789012.dkr.ecr.eu-west-1.amazonaws.com

# ── Application URLs ──────────────────────────────────────────
APP_BASE_URL=https://api.medoq.sn

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_FROM=noreply@medoq.sn
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

# ── Spring profiles ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── CORS (comma-separated allowed origins) ───────────────────
# Add the Angular dashboard domain
MEDOQ_CORS_ALLOWED_ORIGINS=https://dashboard.medoq.sn,https://medoq.sn

# ── Platform config ───────────────────────────────────────────
PLATFORM_START_DATE=2024-01-01
